# PostgreSQL (Dagster metadata store)
POSTGRES_USER=dagster
POSTGRES_PASSWORD=dagster_pass
POSTGRES_DB=dagster

# Project mount path (host path to your Dagster project)
PROJECT_PATH=C:/Users/bibo7/gitrepo/forecasting-platform

# Redshift (direct connection or via SSH tunnel)
REDSHIFT_HOST=your-workgroup.123456789012.us-east-1.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=dev
REDSHIFT_USER=rdadmin
REDSHIFT_PASSWORD=changeme
REDSHIFT_IAM_ROLE=arn:aws:iam::123456789012:role/service-role/AmazonRedshift-CommandsAccessRole

# SSH Bastion Tunnel
BASTION_HOST=bastion.example.com
BASTION_USER=ec2-user
BASTION_PORT=22
SSH_LOCAL_PORT=10022
SSH_REMOTE_HOST=your-workgroup.123456789012.us-east-1.redshift-serverless.amazonaws.com
SSH_REMOTE_PORT=5439

# S3
S3_BUCKET=your-forecast-bucket
AWS_REGION=us-east-1

# AWS Credentials
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key

# AWS Forecast
FORECAST_ROLE_ARN=arn:aws:iam::123456789012:role/ForecastS3Access
FORECAST_DATASET_GROUP_ARN=arn:aws:forecast:us-east-1:123456789012:dataset-group/demand_forecast
FORECAST_DOMAIN=CUSTOM
FORECAST_HORIZON=12
FORECAST_FREQUENCY=W
