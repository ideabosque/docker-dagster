# PostgreSQL (Dagster metadata store)
POSTGRES_USER=dagster
POSTGRES_PASSWORD=dagster_pass
POSTGRES_DB=dagster

# Project mount path (host path to your Dagster project)
# App-level config (Redshift, AWS, S3, Forecast, NetSuite) is loaded
# from the project's own .env file via pydantic-settings.
PROJECT_PATH=C:/path/to/your/forecasting-platform
